<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Ícone -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛡️"
            android:textSize="64sp"
            android:gravity="center"
            android:layout_marginTop="24dp" />

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="M&amp;A Guardian"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Proteção Premium contra pop-ups e adware"
            android:textColor="#F59E0B"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="6dp" />

        <!-- Carregando -->
        <ProgressBar
            android:id="@+id/progressBilling"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tvLoadingPlans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Carregando plano…"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="visible" />

        <!-- Conteúdo principal (oculto durante carregamento) -->
        <LinearLayout
            android:id="@+id/layoutContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Card do plano -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/plan_card_selected">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLANO PREMIUM"
                    android:textColor="#F59E0B"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tvMonthlyPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$ 9,90/mês"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assinatura mensal · Cancele quando quiser"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- Benefícios -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:padding="20dp"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="O que está incluído:"
                    android:textColor="#F59E0B"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Detecção de pop-ups em tempo real"
                    android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Varredura completa de malware e adware"
                    android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Detecção de apps ocultos e espiões"
                    android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Proteção automática ao ligar o celular"
                    android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Notificações imediatas de ameaças"
                    android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Limpeza de cache do dispositivo"
                    android:textColor="#DDDDDD" android:textSize="14sp"/>

            </LinearLayout>

            <!-- Botão assinar -->
            <Button
                android:id="@+id/btnSubscribe"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ASSINAR POR R$ 9,90/MÊS"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#dc2626"
                android:layout_marginTop="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Renovação automática mensal. Cancele quando quiser na Play Store."
                android:textColor="#555555"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <!-- Restaurar -->
            <TextView
                android:id="@+id/btnRestore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Restaurar compra anterior"
                android:textColor="#F59E0B"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginTop="4dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- Termos e Privacidade -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvTerms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Termos de Uso"
                    android:textColor="#444444"
                    android:textSize="11sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ·  "
                    android:textColor="#444444"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvPrivacy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Política de Privacidade"
                    android:textColor="#444444"
                    android:textSize="11sp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
