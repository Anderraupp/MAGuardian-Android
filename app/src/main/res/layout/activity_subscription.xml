<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Ícone + Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛡️"
            android:textSize="56sp"
            android:gravity="center"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="M&amp;A Guardian"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Proteção Premium contra pop-ups e adware"
            android:textColor="#F59E0B"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <!-- Carregando plans -->
        <ProgressBar
            android:id="@+id/progressBilling"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tvLoadingPlans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Carregando planos…"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="visible" />

        <!-- Benefícios -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="16dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="O que está incluído:"
                android:textColor="#F59E0B"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="✅  Detecção de pop-ups em tempo real"
                android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="8dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="✅  Varredura completa de malware e adware"
                android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="8dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="✅  Detecção de apps ocultos e espiões"
                android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="8dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="✅  Proteção automática ao ligar o celular"
                android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="8dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="✅  Notificações imediatas de ameaças"
                android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="8dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="✅  Limpeza de cache do dispositivo"
                android:textColor="#DDDDDD" android:textSize="14sp"/>

        </LinearLayout>

        <!-- Cards de plano -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <!-- Plano Mensal -->
            <LinearLayout
                android:id="@+id/cardPlanMonthly"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/plan_card_selected"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MENSAL"
                    android:textColor="#F59E0B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvMonthlyPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carregando…"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancele quando quiser"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Plano Anual -->
            <LinearLayout
                android:id="@+id/cardPlanYearly"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/plan_card_default"
                android:clickable="true"
                android:focusable="true">

                <!-- Badge "Melhor valor" -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" MELHOR VALOR "
                    android:textColor="#111111"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_popular"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANUAL"
                    android:textColor="#F59E0B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvYearlyPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carregando…"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Economize até 40%"
                    android:textColor="#F59E0B"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

        <!-- Botão de assinatura -->
        <Button
            android:id="@+id/btnSubscribe"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ASSINAR AGORA"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#dc2626"
            android:layout_marginTop="20dp"
            android:enabled="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Renova automaticamente. Cancele a qualquer momento na Play Store."
            android:textColor="#666666"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Restaurar compra -->
        <TextView
            android:id="@+id/btnRestore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restaurar compra anterior"
            android:textColor="#F59E0B"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Termos e Privacidade -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvTerms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Termos de Uso"
                android:textColor="#555555"
                android:textSize="11sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  ·  "
                android:textColor="#555555"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvPrivacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Política de Privacidade"
                android:textColor="#555555"
                android:textSize="11sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
