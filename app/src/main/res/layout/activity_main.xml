<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="24dp">

        <!-- ═══════════════════════════════════════════════
             HEADER: Título à esquerda, botões à direita
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="M&amp;A Guardian"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monitoramento em tempo real"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnScan"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Escanear"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="11sp"
                android:background="@drawable/btn_primary"
                app:backgroundTint="@null"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/btnToggle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Desativar"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="11sp"
                android:background="@drawable/btn_secondary"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════
             AVISO DE PERMISSÕES (oculto quando OK)
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutPermWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_status_inactive"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_shield_alert"
                android:layout_marginEnd="10dp"
                android:contentDescription="Aviso" />

            <TextView
                android:id="@+id/tvPermWarning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/danger"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.3" />

            <Button
                android:id="@+id/btnPermissions"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Corrigir"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="10sp"
                android:background="@drawable/btn_primary"
                app:backgroundTint="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════
             CARD DE STATUS PRINCIPAL
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_status_active"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/shield_bg_circle"
                android:layout_marginEnd="14dp">

                <ImageView
                    android:id="@+id/ivShield"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_shield_check"
                    android:contentDescription="Status" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Proteção Ativa"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvStatusBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seguro"
                        android:textColor="@color/success"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:background="@drawable/badge_success"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStatusDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seu dispositivo está protegido."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Taxa de segurança (direita) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Taxa de segurança"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp"
                    android:gravity="end" />

                <TextView
                    android:id="@+id/tvSecurityRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="@color/primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="end" />

                <TextView
                    android:id="@+id/tvScansClean"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0 scans limpos"
                    android:textColor="@color/text_muted"
                    android:textSize="9sp"
                    android:gravity="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════
             STATS: 4 CARDS EM LINHA HORIZONTAL
             ═══════════════════════════════════════════════ -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Encontradas -->
                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_shield_alert"
                        android:layout_marginBottom="6dp"
                        android:contentDescription="Encontradas" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Encontradas"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvTotalFound"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Removidas -->
                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_shield_check"
                        android:layout_marginBottom="6dp"
                        android:contentDescription="Removidas" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Removidas"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvTotalRemoved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/success"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Escaneamentos -->
                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_shield"
                        android:layout_marginBottom="6dp"
                        android:contentDescription="Escaneamentos" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Escaneamentos"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvTotalScans"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Último Scan -->
                <LinearLayout
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_shield"
                        android:layout_marginBottom="6dp"
                        android:contentDescription="Último scan" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Último Scan"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tvLastScan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nunca"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ═══════════════════════════════════════════════
             AMEAÇAS RECENTES
             ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ameaças Recentes"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvThreatCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 registros"
                    android:textColor="@color/gold"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/badge_danger"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnClearThreats"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="Limpar"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_secondary"
                    app:backgroundTint="@null"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp" />
            </LinearLayout>

            <!-- Estado vazio -->
            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:visibility="visible">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_shield_check"
                    android:alpha="0.35"
                    android:layout_marginBottom="12dp"
                    android:contentDescription="Sem ameaças" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma ameaça detectada"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Execute um escaneamento para verificar seu dispositivo"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Lista de ameaças -->
            <LinearLayout
                android:id="@+id/llThreats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
