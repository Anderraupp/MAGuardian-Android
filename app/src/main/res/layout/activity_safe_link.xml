<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark"
    android:fitsSystemWindows="true">

    <!-- Colored top bar (red=fraud, yellow=suspicious) -->
    <View
        android:id="@+id/viewSafeTopBar"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@color/danger" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Icon -->
            <TextView
                android:id="@+id/tvSafeIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨"
                android:textSize="64sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvSafeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LINK BLOQUEADO"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/danger"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSafeSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Este link foi identificado como provável golpe ou phishing."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="28dp" />

            <!-- URL Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Link detectado:"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvSafeUrl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvSafeScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/danger"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Reasons Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Motivos identificados:"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/llSafeReasons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/surface_dark">

        <Button
            android:id="@+id/btnSafeBack"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="← Voltar (Recomendado)"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/btn_primary"
            app:backgroundTint="@null"
            android:layout_marginBottom="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <Button
            android:id="@+id/btnSafeContinue"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Abrir assim mesmo (risco)"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:background="@null" />
    </LinearLayout>

</LinearLayout>
